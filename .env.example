# Canvas API Configuration
# Required: Your Canvas instance URL
CANVAS_API_URL=https://your-school.instructure.com

# Required: Your Canvas API token
# Generate at: Canvas > Account > Settings > Approved Integrations > New Access Token
CANVAS_API_TOKEN=your-canvas-api-token-here

# Optional: Default course ID (can also be set via Settings UI)
CANVAS_COURSE_ID=

# Optional: Path to the data directory for SQLite database and logs
# Defaults to ./data (local). Set to a OneDrive/SharePoint path for FERPA-compliant shared storage.
# Example (Georgia Tech OneDrive):
#   DATA_PATH=/Users/yourname/Library/CloudStorage/OneDrive-GeorgiaInstituteofTechnology/ISYE6740 TA Sharepoint/TA Dashboard
DATA_PATH=
